generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────

enum Role {
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  ON_DUTY
  LATE
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  QUEUED
}

// ─── Organization (Multi-Tenant Root) ────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String                          // "Global Institute of Technology"
  code      String   @unique               // "GIT"
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  classes        Class[]
  students       Student[]
  teachers       Teacher[]
  parents        Parent[]
  notifications  NotificationLog[]

  @@index([code])
}

// ─── Teacher ─────────────────────────────────────────────────

model Teacher {
  id             String       @id @default(cuid())
  name           String
  email          String       @unique
  phone          String?
  passwordHash   String                    // bcrypt hash, never plaintext
  role           Role         @default(TEACHER)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  attendanceLogs AttendanceLog[]          // records they marked

  @@index([organizationId])
  @@index([email])
}

// ─── Class ───────────────────────────────────────────────────

model Class {
  id             String       @id @default(cuid())
  name           String                    // "Computer Science 101"
  year           Int                       // academic year: 2024
  semester       Int          @default(1)  // 1 or 2
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  students       Student[]
  attendanceLogs AttendanceLog[]
  marks          Marks[]

  @@unique([name, organizationId, year, semester])
  @@index([organizationId])
}

// ─── Student ─────────────────────────────────────────────────

model Student {
  id             String       @id @default(cuid())
  name           String
  rollNumber     String
  email          String?
  phone          String?
  batch          String?                   // "Batch A", "Batch B"
  passwordHash   String                   // bcrypt hash
  role           Role         @default(STUDENT)
  classId        String
  class          Class        @relation(fields: [classId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  attendanceLogs AttendanceLog[]
  marks          Marks[]
  parents        Parent[]
  notifications  NotificationLog[]

  @@unique([rollNumber, organizationId])    // roll unique per org
  @@index([classId])
  @@index([organizationId])
  @@index([organizationId, classId])        // composite for filtered queries
}

// ─── Parent ──────────────────────────────────────────────────

model Parent {
  id             String       @id @default(cuid())
  name           String
  phone          String
  email          String?
  passwordHash   String                   // bcrypt hash
  role           Role         @default(PARENT)
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([phone, organizationId])        // unique per org
  @@index([studentId])
  @@index([organizationId])
}

// ─── Marks (Normalized — Per Subject/Semester) ───────────────

model Marks {
  id             String   @id @default(cuid())
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id])
  classId        String
  class          Class    @relation(fields: [classId], references: [id])
  subject        String                   // "Data Structures", "OS"
  semester       Int                      // 1, 2, etc.
  year           Int                      // academic year

  // Individual components
  cia1           Float    @default(0)     // out of 2.5
  cia2           Float    @default(0)     // out of 2.5
  test1          Float    @default(0)     // raw out of 40
  test2          Float    @default(0)     // raw out of 40
  assignment     Float    @default(0)     // out of 10

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([studentId, classId, subject, semester, year])
  @@index([studentId])
  @@index([classId])
  @@index([studentId, classId])
}

// ─── Attendance Log ──────────────────────────────────────────

model AttendanceLog {
  id             String           @id @default(cuid())
  date           DateTime
  lectureNumber  Int              @default(1)
  status         AttendanceStatus
  studentId      String
  student        Student          @relation(fields: [studentId], references: [id])
  classId        String
  class          Class            @relation(fields: [classId], references: [id])
  markedById     String?                   // who marked it
  markedBy       Teacher?         @relation(fields: [markedById], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Prevent duplicate entries for the same student, date, lecture
  @@unique([date, studentId, lectureNumber])
  @@index([studentId])
  @@index([classId])
  @@index([date])
  @@index([studentId, date])               // for date-range student queries
  @@index([classId, date])                 // for daily class view
}

// ─── Notification Log ────────────────────────────────────────

model NotificationLog {
  id             String             @id @default(cuid())
  studentId      String
  student        Student            @relation(fields: [studentId], references: [id])
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id])
  message        String
  channel        String             @default("SMS")  // SMS, WHATSAPP, EMAIL
  status         NotificationStatus @default(PENDING)
  sentAt         DateTime?
  error          String?                              // store failure reason
  createdAt      DateTime           @default(now())

  @@index([studentId])
  @@index([organizationId])
  @@index([status])                                   // for retry queries
}
